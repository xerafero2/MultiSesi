<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeWidth="1dp"
    app:strokeColor="#E2E8F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/tvBadgeId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_outline"
                android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingTop="4dp" android:paddingBottom="4dp"
                android:text="5" android:textSize="12sp" android:textStyle="bold" android:textColor="#0F172A"/>
            <TextView
                android:id="@+id/tvBadgeYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/badge_red_light"
                android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="4dp" android:paddingBottom="4dp"
                android:text="2004" android:textSize="12sp" android:textStyle="bold" android:textColor="#E11D48"/>
            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
            <TextView
                android:id="@+id/tvPlatformTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_outline"
                android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="6dp" android:paddingBottom="6dp"
                android:text="FACEBOOK" android:textSize="11sp" android:textStyle="bold" android:textColor="#0F172A"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical">
            <com.google.android.material.card.MaterialCardView
                android:layout_width="48dp" android:layout_height="48dp"
                app:cardCornerRadius="24dp" app:cardBackgroundColor="#1877F2" app:strokeWidth="0dp">
                <TextView android:id="@+id/tvPlatformInitial" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="f" android:textSize="28sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
            </com.google.android.material.card.MaterialCardView>
            <LinearLayout
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:orientation="vertical" android:layout_marginStart="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:id="@+id/tvUsername" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="xera_fero@gmail.com" android:textSize="16sp" android:textStyle="bold" android:textColor="#0F172A"/>
                    <ImageView android:id="@+id/btnCopyUser" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_agenda" app:tint="#64748B" android:padding="2dp" android:background="?attr/selectableItemBackgroundBorderless" android:clickable="true" android:focusable="true"/>
                </LinearLayout>
                
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp" android:background="@drawable/bg_password_box" android:padding="12dp" android:gravity="center_vertical">
                    <TextView android:id="@+id/tvPassword" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="••••••••" android:textSize="18sp" android:textColor="#0F172A" android:letterSpacing="0.2"/>
                    <ImageView android:id="@+id/btnTogglePass" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_view" app:tint="#64748B" android:background="?attr/selectableItemBackgroundBorderless" android:clickable="true" android:focusable="true"/>
                    <ImageView android:id="@+id/btnCopyPass" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginStart="16dp" android:src="@android:drawable/ic_menu_agenda" app:tint="#64748B" android:background="?attr/selectableItemBackgroundBorderless" android:clickable="true" android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="20dp" android:layout_marginBottom="16dp" android:background="#E2E8F0" />

        <TextView android:id="@+id/tvCreationDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/badge_red_solid" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="6dp" android:paddingBottom="6dp" android:text="1 Juni 2009" android:textSize="11sp" android:textStyle="bold" android:textColor="#FFFFFF" />

        <LinearLayout
            android:id="@+id/layout2FA"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginTop="12dp"
            android:background="@drawable/bg_2fa_box" android:padding="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2-FACTOR CODE" android:textSize="10sp" android:textStyle="bold" android:textColor="#64748B" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="4dp">
                <TextView android:id="@+id/tv2FaCode" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="153974" android:textSize="28sp" android:textStyle="bold" android:textColor="#E11D48" android:letterSpacing="0.1"/>
                <ImageView android:id="@+id/btnCopy2Fa" android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_menu_agenda" app:tint="#64748B" android:background="?attr/selectableItemBackgroundBorderless" android:clickable="true" android:focusable="true"/>
            </LinearLayout>
            <ProgressBar android:layout_width="match_parent" android:layout_height="4dp" android:layout_marginTop="8dp" style="?android:attr/progressBarStyleHorizontal" android:progress="70" android:progressTint="#E11D48" android:progressBackgroundTint="#E2E8F0" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="48dp" android:orientation="horizontal" android:layout_marginTop="16dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/btnEditProfile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Edit" android:textColor="#0F172A" app:backgroundTint="#F8FAFC" app:strokeWidth="1dp" app:strokeColor="#E2E8F0" app:icon="@android:drawable/ic_menu_edit" app:iconTint="#0F172A" app:iconGravity="textStart" app:cornerRadius="12dp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnLaunchBrowser" android:layout_width="48dp" android:layout_height="match_parent" android:layout_marginStart="8dp" app:backgroundTint="#EFF6FF" app:icon="@android:drawable/ic_menu_set_as" app:iconTint="#2563EB" app:iconGravity="textStart" app:iconPadding="0dp" app:cornerRadius="12dp" style="@style/Widget.MaterialComponents.Button.IconOnly"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnDeleteProfile" android:layout_width="48dp" android:layout_height="match_parent" android:layout_marginStart="8dp" app:backgroundTint="#FFF1F2" app:icon="@android:drawable/ic_menu_delete" app:iconTint="#E11D48" app:iconGravity="textStart" app:iconPadding="0dp" app:cornerRadius="12dp" style="@style/Widget.MaterialComponents.Button.IconOnly"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="16dp">
            <TextView android:id="@+id/tvDateCreated" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Dibuat: -" android:textSize="10sp" android:textColor="#94A3B8" />
            <TextView android:id="@+id/tvDateUpdated" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Update: -" android:textSize="10sp" android:textColor="#94A3B8" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
