<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8FAFC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:elevation="2dp">
        <ImageView android:id="@+id/btnCloseDialog" android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_close_clear_cancel" app:tint="#0F172A" android:background="?attr/selectableItemBackgroundBorderless" android:clickable="true" android:focusable="true"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Tambah Akun" android:textSize="18sp" android:textStyle="bold" android:textColor="#0F172A"/>
        <TextView android:id="@+id/btnSaveTop" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Simpan" android:textSize="16sp" android:textStyle="bold" android:textColor="#E11D48" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:padding="8dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">

            <EditText android:id="@+id/etPlatform" android:layout_width="match_parent" android:layout_height="56dp" android:background="@drawable/bg_input_box" android:hint="Singkatan / Platform (Opsional)" android:paddingStart="16dp" android:paddingEnd="16dp" android:textColor="#0F172A" android:textColorHint="#94A3B8" android:textSize="15sp" android:layout_marginBottom="16dp" />
            <EditText android:id="@+id/etUsername" android:layout_width="match_parent" android:layout_height="56dp" android:background="@drawable/bg_input_box" android:hint="Email atau Username" android:paddingStart="16dp" android:paddingEnd="16dp" android:textColor="#0F172A" android:textColorHint="#94A3B8" android:textSize="15sp" android:layout_marginBottom="16dp" />
            <EditText android:id="@+id/etPassword" android:layout_width="match_parent" android:layout_height="56dp" android:background="@drawable/bg_input_box" android:hint="Password Akun" android:inputType="textPassword" android:paddingStart="16dp" android:paddingEnd="16dp" android:textColor="#0F172A" android:textColorHint="#94A3B8" android:textSize="15sp" android:layout_marginBottom="16dp" />
            
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
                <EditText android:id="@+id/etBirthDate" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:background="@drawable/bg_input_box" android:hint="Tgl Lahir" android:paddingStart="16dp" android:paddingEnd="16dp" android:textColor="#0F172A" android:textColorHint="#94A3B8" android:textSize="15sp" android:layout_marginEnd="8dp"/>
                <EditText android:id="@+id/etYearCreated" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:background="@drawable/bg_input_box" android:hint="Tahun Buat" android:inputType="number" android:paddingStart="16dp" android:paddingEnd="16dp" android:textColor="#0F172A" android:textColorHint="#94A3B8" android:textSize="15sp" android:layout_marginStart="8dp"/>
            </LinearLayout>

            <EditText android:id="@+id/etCategory" android:layout_width="match_parent" android:layout_height="56dp" android:background="@drawable/bg_input_box" android:hint="Kategori / Game (pisahkan koma)" android:paddingStart="16dp" android:paddingEnd="16dp" android:textColor="#0F172A" android:textColorHint="#94A3B8" android:textSize="15sp" android:layout_marginBottom="24dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="72dp" android:orientation="horizontal" android:background="@drawable/bg_input_box" android:gravity="center_vertical" android:paddingStart="20dp" android:paddingEnd="20dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Aktifkan 2-Factor Code" android:textSize="16sp" android:textStyle="bold" android:textColor="#0F172A"/>
                <Switch android:id="@+id/switch2FA" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>
            <EditText android:id="@+id/et2FASecret" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="16dp" android:background="@drawable/bg_input_box" android:hint="Masukkan Base32 Secret 2FA..." android:paddingStart="16dp" android:paddingEnd="16dp" android:textColor="#0F172A" android:textColorHint="#94A3B8" android:textSize="15sp" android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveBottom"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="48dp"
                android:text="Simpan Akun Baru"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:cornerRadius="16dp"
                app:backgroundTint="#E11D48" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
